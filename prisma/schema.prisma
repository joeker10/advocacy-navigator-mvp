// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Document {
  id        String   @id @default(uuid())
  fileName  String
  hash      String   // For verified provenance
  createdAt DateTime @default(now())
  status    String   // 'VERIFIED', 'PENDING'

  // Extracted fields mapped according to HAR Chapter 60
  plaafp               String?
  lreStatement         String?
  
  goals                AnnualGoal[]
  accommodations       Accommodation[]
  relatedServices      RelatedService[]
}

model AnnualGoal {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  target     String
  benchmarks String?
}

model Accommodation {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  details    String
}

model RelatedService {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  type       String   // e.g. "Speech Therapy", "OT"
  frequency  String
  duration   String
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  subscriptionStatus String    @default("UNSUBSCRIBED") // 'SUBSCRIBED', 'UNSUBSCRIBED'
  subscriptionTier   String    @default("FREE")        // 'FREE', 'PARENT', 'PROFESSIONAL'
  profileLimit       Int       @default(1)             // 1 for FREE, 3 for PARENT, 9999 for PROFESSIONAL
  parentId           String?   // Linked parent account for Family Discount tier
  createdAt          DateTime  @default(now())
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  twoFactorExpires   DateTime?
  emailVerified      Boolean   @default(false)
  verificationToken  String?
  verificationExpires DateTime?
  childProfiles      ChildProfile[]
  savedInsights      SavedInsight[]
}

model ChildProfile {
  id        String         @id
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  school    String?
  grade     String?
  dob       String?
  createdAt DateTime       @default(now())
  insights  SavedInsight[]
}

model SavedInsight {
  id        String        @id
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  childId   String?
  child     ChildProfile? @relation(fields: [childId], references: [id], onDelete: Cascade)
  query     String
  response  String
  name      String?
  timestamp DateTime      @default(now())
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  isActive        Boolean  @default(true)
  discountType    String   @default("PERCENT") // "PERCENT" or "FIXED"
  discountValue   Float    @default(100.0)
  applicablePlan  String   @default("ALL")     // "ALL", "MONTHLY", "THREE_MONTH", "ANNUAL"
  isOneTimeUse    Boolean  @default(true)
  deployedTo      String   @default("")
  createdAt       DateTime @default(now())
}

model Post {
  id        String   @id @default(uuid())
  title     String
  category  String
  excerpt   String
  content   String
  date      String
  createdAt DateTime @default(now())
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  description String
  fileName    String
  fileContent String
  createdAt   DateTime @default(now())
}

model Video {
  id          String   @id @default(uuid())
  title       String
  description String
  youtubeId   String   // The 11-character YouTube video ID
  type        String   // 'short' or 'video'
  category    String   // 'IEP Timelines', 'HAR Chapter 60', etc.
  duration    String   // e.g. '0:58' or '12:30'
  releasedAt  String   // e.g. 'June 2026'
  createdAt   DateTime @default(now())
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}
